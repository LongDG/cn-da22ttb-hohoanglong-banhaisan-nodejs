# Example environment configuration for Backend
# Copy this file to .env and adjust values.

# Strong JWT secret (use >=32 random chars, avoid common words)
JWT_SECRET=change_this_to_a_very_strong_secret_value_32chars_min

# Mongo connection string
MONGO_URI=mongodb://localhost:27017/BIENTUOI_DB

# Server port (optional)
PORT=3000
